{
  "name": "rwa-marketplace-backend",
  "version": "2.0.0",
  "description": "Off-chain metadata API for RWA marketplace",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "deploy": "echo 'Push to main — Render auto-deploys via render.yaml'",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "migrate:status": "knex migrate:list",
    "lint": "eslint . --ext .js",
    "lint:ci": "eslint . --ext .js --max-warnings=0",
    "lint:fix": "eslint . --ext .js --fix",
    "bootstrap-api-key": "node bootstrap-api-key.js",
    "backup": "node backup.js",
    "backup:list": "node backup.js --list",
    "backup:verify": "node backup.js --verify-latest",
    "restore": "node restore.js"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./__tests__/setup.js",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__tests__/setup.js"
    ],
    "transform": {}
  },
  "dependencies": {
    "@apollo/server": "^4.10.1",
    "@sentry/node": "^10.60.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-prom-bundle": "^7.0.0",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.6",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.7",
    "graphql-ws": "^5.16.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "mjml": "^4.15.3",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.13",
    "pg": "^8.14.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "prettier": "^3.9.1",
    "supertest": "^7.0.0"
  }
}
