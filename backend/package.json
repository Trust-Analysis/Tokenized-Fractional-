{
  "name": "rwa-marketplace-backend",
  "version": "2.0.0",
  "description": "Off-chain metadata API for RWA marketplace",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "deploy": "echo 'Push to main — Render auto-deploys via render.yaml'",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "migrate:status": "knex migrate:list"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./__tests__/setup.js",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__tests__/setup.js"
    ],
    "transform": {}
  },
  "dependencies": {
    "@sentry/node": "^10.60.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-prom-bundle": "^7.0.0",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.6",
    "helmet": "^7.1.0",
    "prom-client": "^15.1.0",
    "ioredis": "^5.11.1",
    "knex": "^3.1.0",
    "multer": "^2.2.0",
    "pg": "^8.14.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
