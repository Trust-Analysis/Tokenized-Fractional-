{
  "name": "rwa-marketplace-backend",
  "version": "2.0.0",
  "description": "Off-chain metadata API for RWA marketplace",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "deploy": "echo 'Push to main — Render auto-deploys via render.yaml'",
    "lint": "eslint . --ext .js --max-warnings=0",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./__tests__/setup.js",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__tests__/setup.js"
    ],
    "transform": {}
  },
  "dependencies": {
    "@sentry/node": "^10.60.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "knex": "^3.1.0",
    "pg": "^8.14.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^29.7.0",
    "prettier": "^3.9.1",
    "supertest": "^7.0.0"
  }
}
