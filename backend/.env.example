# ── Required ──────────────────────────────────────────────────────────────────

# Admin API key used to authenticate write operations (POST /api/rwa, DELETE /api/rwa/:id).
# Must be at least 16 characters. Generate with: openssl rand -hex 32
ADMIN_API_KEY=change-me-to-a-random-secret-key-min-16-chars

# Comma-separated list of origins allowed by CORS.
# Example for production: https://your-frontend.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Optional (safe defaults shown) ────────────────────────────────────────────

# Port the HTTP server listens on. Must be 1–65535.
# PORT=3001

# Path to the JSON data file, relative to the backend directory.
# DATA_FILE=data.json

# Runtime environment. Set to "production" in deployed environments.
# NODE_ENV=development

# Minimum log level: trace | debug | info | warn | error | fatal | silent
# LOG_LEVEL=info

# Database URL (used by Knex migrations)
# SQLite (development): leave as default or set a file path
# DATABASE_URL=./dev.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis configuration (optional — falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# How long (seconds) cached API responses are kept. Must be a positive integer.
# CACHE_TTL_SECONDS=60

# ── Optional Sentry (error tracking disabled when unset) ──────────────────────

# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1


# ── IPFS / Pinata (required for document uploads) ──────────────────────────

# JWT token from your Pinata account (app.pinata.cloud → API Keys → New Key).
# Grant at minimum: pinFileToIPFS, unpin permissions.
# PINATA_JWT=your-pinata-jwt-here

# IPFS gateway base URL. Defaults to the public Pinata gateway.
# You can use any public gateway, e.g. https://cloudflare-ipfs.com
# PINATA_GATEWAY=https://gateway.pinata.cloud